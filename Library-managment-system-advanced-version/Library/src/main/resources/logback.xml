<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Silence logback's own startup INFO messages -->
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

    <!-- Console: clean format, app logs only -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{HH:mm:ss} %-5level %logger{30} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File: full detail, daily rollover -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/libracore.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/libracore.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress noisy third-party loggers -->
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="org.xerial"        level="WARN"/>
    <logger name="org.apache.poi"    level="ERROR"/>
    <logger name="com.sun.mail"      level="WARN"/>

    <!-- App code: INFO+ to both console and file -->
    <logger name="com.library" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Everything else: WARN+ to file only -->
    <root level="WARN">
        <appender-ref ref="FILE"/>
    </root>

</configuration>
